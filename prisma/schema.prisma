// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MonthlyIndex {
  id          String   @id @default(cuid())
  month       String   @unique // "2026-03"
  year        Int
  month_num   Int      // 1-12

  // Scores
  totalScore        Float
  fundingScore      Float
  jobPostingScore   Float
  newsVolumeScore   Float
  pollScore         Float

  fundingWeight     Float @default(0.30)
  jobPostingWeight  Float @default(0.25)
  newsVolumeWeight  Float @default(0.25)
  pollWeight        Float @default(0.20)

  rawFundingDeals   Int?
  rawFundingValue   Float?   // USD millions
  rawJobPostings    Int?
  rawNewsArticles   Int?
  rawPollAvg        Float?
  rawPollCount      Int?

  commentary        String   @db.Text
  summaryVi         String?  // Tóm tắt ngắn tiếng Việt
  summaryEn         String?  // Tóm tắt ngắn tiếng Anh

  isPublished       Boolean  @default(false)
  publishedAt       DateTime?

  sectorScores      SectorScore[]
  auditLogs         AuditLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([year, month_num])
  @@index([isPublished])
}

model SectorScore {
  id          String   @id @default(cuid())
  indexId     String
  index       MonthlyIndex @relation(fields: [indexId], references: [id])

  sector      String   // "fintech" | "ecommerce" | "edtech" | "healthtech" | "deeptech"
  score       Float
  trend       Float?   // delta vs previous month

  createdAt   DateTime @default(now())

  @@unique([indexId, sector])
  @@index([sector])
}

model Poll {
  id          String   @id @default(cuid())
  month       String   @unique // "2026-03"
  question    String
  isOpen      Boolean  @default(true)
  closedAt    DateTime?

  responses   PollResponse[]

  createdAt   DateTime @default(now())
}

model PollResponse {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id])

  rating    Int      // 1-5
  ipHash    String   // SHA-256 hashed IP — không lưu raw
  userAgent String?

  createdAt DateTime @default(now())

  @@unique([pollId, ipHash])
  @@index([pollId])
}

model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  isVerified  Boolean  @default(false)
  verifyToken String?  @unique
  source      String?  // "homepage" | "archive" | "share_card"

  unsubscribedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isVerified])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      String   @default("admin") // "admin" | "editor"

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  indexId   String?
  index     MonthlyIndex? @relation(fields: [indexId], references: [id])

  action    String   // "publish" | "update" | "unpublish"
  details   Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([indexId])
}

model PageView {
  id        String   @id @default(cuid())
  page      String
  referrer  String?
  country   String?
  createdAt DateTime @default(now())

  @@index([page, createdAt])
}